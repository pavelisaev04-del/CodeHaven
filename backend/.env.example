# ── Основное ──────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=generate-a-strong-secret-key-here
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ── База данных (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/legalservice

# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook

# ── Платежи: ЮКасса (основной для РФ) ─────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Платежи: Stripe (международный) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Calendly ──────────────────────────────────────────────────────────────────
CALENDLY_API_KEY=
CALENDLY_USER_URI=https://api.calendly.com/users/...

# ── Zoom (Server-to-Server OAuth App) ─────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Email: SendGrid ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com

# ── Хранилище файлов ──────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
# Для S3:
# STORAGE_BACKEND=s3
# AWS_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
