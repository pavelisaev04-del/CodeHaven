# PostgreSQL connection string
DATABASE_URL=postgresql://aegis:password@localhost:5432/aegis

# JWT secrets — must be long random strings (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-here

# DeepSeek API key — получить на platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL root password (used in docker-compose)
POSTGRES_PASSWORD=strongpassword

# Server port
PORT=3001

# Environment: development | production
NODE_ENV=development

# Allowed CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:5173
